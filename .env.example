# Hearth — environment variables
# Copy to .env.local and fill in. NEVER commit real values (.env* is gitignored).

# --- Supabase (public, browser-safe — constrained by Row-Level Security) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- Supabase service role (SERVER ONLY — bypasses RLS; never expose to client) ---
# Used by trusted server actions for public submissions/reports and the calendar import.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Google Calendar seed import ---
# Reads the calendar's PUBLIC iCal feed — no API key required.
# Source calendar: "Conscious Events TO Calendar"
GOOGLE_CALENDAR_ID=consciouseventsto@gmail.com
# Import events from this date forward (whole-year archive)
EVENT_IMPORT_FROM=2026-01-01

# --- Admin panel ---
# Comma-separated emails allowed into /admin (the login allowlist). Each must
# also be a real user in Supabase Auth (Dashboard → Authentication → Add user).
ADMIN_EMAILS=you@example.com

# --- Admin email notifications ---
# Emails when a listing is held for review or crosses the report threshold.

# WHO gets alerted — decoupled from admin-panel access. Set this to control the
# recipients independently of ADMIN_EMAILS (e.g. several people can moderate, but
# only some are emailed). If unset, alerts fall back to ADMIN_EMAILS.
# NOTE: on Resend's onboarding sender, keep this to the single Resend-account
# inbox (multi-recipient sends are rejected until a domain is verified).
NOTIFY_EMAILS=

# HOW they're sent — set EITHER option below (Resend is used if both are set).
# If neither is set, alerts log to the server console instead of sending — the
# app still builds and runs without them.

# Option A — Resend (easiest: no new email account, no domain, no app password).
# Sign in at https://resend.com (you can "Sign in with Google" using an existing
# Gmail) → API Keys → create one. Emails send FROM onboarding@resend.dev and —
# until you verify a domain — deliver only to the email your Resend account uses.
# Perfect for a single-steward pilot; verify a domain + set RESEND_FROM (e.g.
# "Hearth <alerts@yourdomain.com>") to reach multiple admins.
RESEND_API_KEY=
RESEND_FROM=

# Option B — Gmail SMTP (send from a Gmail you control; no recipient limit).
# Needs a Google "App Password" (NOT the account's normal password):
#   Google Account → Security → 2-Step Verification (must be ON) → App passwords
#   → create one for "Mail" → paste the 16-character password below.
GMAIL_USER=
GMAIL_APP_PASSWORD=

# --- Site URL (for absolute links inside notification emails) ---
# Defaults to https://myhearthapp.ca (the production domain; the old
# hearthto.vercel.app URL still serves as an alias). Override if needed.
NEXT_PUBLIC_SITE_URL=https://myhearthapp.ca

# --- Vercel Cron (daily auto-import) ---
# Set in Vercel only. Vercel Cron sends `Authorization: Bearer <CRON_SECRET>`
# to /api/cron/import; the route rejects anything else. Leave unset locally
# (the endpoint is then open so you can trigger it by hand in dev).
CRON_SECRET=
